#!/bin/sh

get_platform() {
  local os arch
  os=$(uname -s | tr '[:upper:]' '[:lower:]')
  arch=$(uname -m)

  case "$arch" in
    x86_64|amd64) arch="amd64";;
  esac

  echo "$os-$arch"
}

has_cmd() {
  command -v "$1" > /dev/null 2>&1
}

log() {
  local prefix red green yellow blue nc
  red='\033[0;31m'
  green='\033[0;32m'
  yellow='\033[1;33m'
  blue='\033[0;34m'
  nc='\033[0m'

  case "$1" in
    debug) prefix="$blue[DEBUG]";;
    info) prefix="$nc[INFO]";;
    success) prefix="$green[SUCCESS]";;
    warning) prefix="$yellow[WARNING]";;
    error) prefix="$red[ERROR]";;
    *)
      echo "Usage: log <level> <message>"
      echo "level: debug, info, success, warning, error"
      return 0;;
  esac

  printf "$prefix $2$nc\n" >&2
}

die() {
  local help="false" clean="false"
  case "$1" in
    help) help="true"; shift;;
    clean) clean="true"; shift;;
  esac
  log error "$1"
  [ "$help" = "true" ] && has_cmd usage && usage
  [ "$clean" = "true" ] && has_cmd cleanup && cleanup
  exit 1
}

get_opt() {
  local option_name="$1"
  local next_arg="$2"

  if [ -z "$next_arg" ] || [ "${next_arg#-}" != "$next_arg" ]; then
    die help "$option_name requires a value"
  fi
  echo "$next_arg"
}

